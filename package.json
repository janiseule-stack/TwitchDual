{
  "name": "twitchdual",
  "version": "1.8.2",
  "description": "Zwei-Fenster Twitch-Viewer (Video + Chat mit 7TV-Emotes) fuer Hochkant-Monitore",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "shots": "electron tools/ui-shots.js",
    "pack": "electron-packager . TwitchDual --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"^/docs$\" --ignore=\"^/test$\"",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "de.janis.twitchdual",
    "productName": "TwitchDual",
    "directories": {
      "output": "dist/installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "vendor/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "janiseule-stack",
        "repo": "TwitchDual"
      }
    ]
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "ws": "^8.21.1"
  }
}
